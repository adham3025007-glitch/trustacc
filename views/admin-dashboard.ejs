<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <header class="page-header">
      <div>
        <h1>Admin Dashboard</h1>
        <p>Signed in as <strong><%= currentUser.username %></strong></p>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="secondary">Logout</button>
      </form>
    </header>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="success"><%= success %></div>
    <% } %>

    <section class="card">
      <h2>Create User</h2>
      <form action="/admin/users" method="POST" class="form">
        <label>Username
          <input type="text" name="username" minlength="3" maxlength="30" required />
        </label>

        <label>Password
          <input type="password" name="password" minlength="8" required />
        </label>

        <label>Confirm Password
          <input type="password" name="confirmPassword" minlength="8" required />
        </label>

        <label>Role
          <select name="role" required>
            <option value="user" selected>User</option>
            <option value="admin">Admin</option>
          </select>
        </label>

        <p class="hint">Username: 3-30 chars using letters, numbers, dot, underscore, dash. Password: min 8 chars.</p>
        <button type="submit">Create User</button>
      </form>
    </section>

    <section class="card">
      <h2>Upload and Assign File</h2>
      <form action="/admin/upload" method="POST" enctype="multipart/form-data" class="form">
        <label>Choose User
          <select name="assignedUserId" required>
            <option value="">Select a user</option>
            <% normalUsers.forEach(function(user) { %>
              <option value="<%= user.id %>"><%= user.username %></option>
            <% }) %>
          </select>
        </label>

        <label>File
          <input type="file" name="file" required />
        </label>

        <p class="hint">Allowed: PDF, TXT, PNG, JPG, DOC, DOCX, XLS, XLSX. Max size: 10MB.</p>
        <button type="submit">Upload</button>
      </form>
    </section>

    <section class="card">
      <h2>All Users</h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Role</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(user) { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.username %></td>
              <td><%= user.role %></td>
              <td><%= user.created_at %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>Assigned Files</h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>File Name</th>
            <th>Assigned User</th>
            <th>Uploaded By</th>
            <th>Size (KB)</th>
            <th>Date</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% if (files.length === 0) { %>
            <tr>
              <td colspan="7">No files uploaded yet.</td>
            </tr>
          <% } %>

          <% files.forEach(function(file) { %>
            <tr>
              <td><%= file.id %></td>
              <td><%= file.original_name %></td>
              <td><%= file.assigned_user %></td>
              <td><%= file.uploaded_by %></td>
              <td><%= (file.size_bytes / 1024).toFixed(2) %></td>
              <td><%= file.upload_date %></td>
              <td><a href="/admin/files/<%= file.id %>/download">Download</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
