<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Dashboard</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <header class="page-header">
      <div>
        <h1>User Dashboard</h1>
        <p>Signed in as <strong><%= currentUser.username %></strong></p>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="secondary">Logout</button>
      </form>
    </header>

    <section class="card">
      <h2>Your Assigned Files</h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>File Name</th>
            <th>Size (KB)</th>
            <th>Uploaded Date</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% if (files.length === 0) { %>
            <tr>
              <td colspan="5">No files assigned yet.</td>
            </tr>
          <% } %>

          <% files.forEach(function(file) { %>
            <tr>
              <td><%= file.id %></td>
              <td><%= file.original_name %></td>
              <td><%= (file.size_bytes / 1024).toFixed(2) %></td>
              <td><%= file.upload_date %></td>
              <td><a href="/user/files/<%= file.id %>/download">Download</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
